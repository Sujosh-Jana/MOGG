rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // All ranked data (institutions, candidates, nominations, votes, users,
    // ranked_audit) is read and written exclusively by the backend via the
    // Firebase Admin SDK, which bypasses these rules. Clients never talk to
    // Firestore directly for this feature, so deny everything here.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
